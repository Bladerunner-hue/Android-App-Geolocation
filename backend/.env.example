# Fail-closed: GEO_DATABASE_URL + JWT_SECRET are required for non-test runs.
# Local bootstrap (PostGIS + pgvector schema):
#   ./scripts/init_geojournal_db.sh
# Default dev password set by that script — change for anything non-local.
GEO_DATABASE_URL=postgresql://geojournal:geojournal_dev_change_me@127.0.0.1:5432/geojournal
JWT_SECRET=generate-a-long-random-secret
GEO_MEDIA_ROOT=./backend/media_store
GEO_MAX_PHOTO_BYTES=8388608
GEO_MAX_AUDIO_BYTES=1048576
GEO_CORS_ORIGINS=*
GEO_ENRICHMENT_ENABLED=0
GEO_BIND_HOST=127.0.0.1
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Semantic text encoder (1024-D → memory_semantic_embeddings). Not fusion_v0.
GEO_SEMANTIC_MODEL=intfloat/multilingual-e5-large-instruct

# Local SQLite without Postgres (optional for smoke runs / pytest only):
# GEO_DATABASE_URL=sqlite+pysqlite:///./backend/geojournal.db

# Seed a local demo account on startup (never enable in production).
GEO_SEED_DEMO_USER=0
GEO_DEMO_USERNAME=demo
GEO_DEMO_EMAIL=demo@localhost
GEO_DEMO_PASSWORD=demo-pass-change-me
