# Fail-closed: GEO_DATABASE_URL + JWT_SECRET are required for non-test runs.
# Prefer repo-root .env (see docs/DATABASE.md). Example shape matches EffuzionBridge DSN:
#   DATABASE_URL=postgresql://USER:PASS@localhost:5432/EffuzionBridgePhoneApp
#   GEO_DATABASE_URL=$DATABASE_URL
GEO_DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/EffuzionBridgePhoneApp
JWT_SECRET=generate-a-long-random-secret
GEO_MEDIA_ROOT=./backend/media_store
GEO_MAX_PHOTO_BYTES=8388608
GEO_MAX_AUDIO_BYTES=1048576
GEO_CORS_ORIGINS=*
GEO_ENRICHMENT_ENABLED=0
GEO_BIND_HOST=127.0.0.1
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Direct E5 HTTP service (OpenAI-compatible embeddings API)
# Health: GET  http://127.0.0.1:6100/health  → {"status":"ok","model":"intfloat/e5-large-v2","dim":1024}
# Embed:  POST http://127.0.0.1:6100/v1/embeddings
GEO_E5_BASE_URL=http://127.0.0.1:6100
GEO_SEMANTIC_MODEL=intfloat/e5-large-v2
# Optional OpenClaw memory bridge (calls E5 on 6100): http://127.0.0.1:6200/v1/

# Local SQLite without Postgres (optional for smoke runs / pytest only):
# GEO_DATABASE_URL=sqlite+pysqlite:///./backend/geojournal.db

# Seed a local demo account on startup (never enable in production).
GEO_SEED_DEMO_USER=0
GEO_DEMO_USERNAME=demo
GEO_DEMO_EMAIL=demo@localhost
GEO_DEMO_PASSWORD=demo-pass-change-me
