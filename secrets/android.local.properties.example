## Copy relevant keys into the repo-root local.properties (gitignored).
## Android Studio usually creates local.properties with sdk.dir automatically.

# sdk.dir=/home/YOU/Android/Sdk

# Emulator alias for host localhost (default in debug BuildConfig)
MEMORY_API_BASE_URL=http://10.0.2.2:8000/

# Physical device on same LAN (example)
# MEMORY_API_BASE_URL=http://192.168.1.42:8000/

# Release / staging HTTPS (must be https:// for non-debug builds)
# MEMORY_API_BASE_URL=https://api.example.com/
